
FROM node:22-alpine

# App directory
WORKDIR /app

# Install 9router globally
RUN npm i -g 9router@0.4.39

# Runtime port (override with -e PORT=xxxx)
ENV PORT=3000
EXPOSE 3000

# Basic container healthcheck: verifies the HTTP server responds on PORT.
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- "http://127.0.0.1:${PORT}/" >/dev/null || exit 1

# Run 9router
CMD ["sh", "-c", "9router --port ${PORT}"]
